# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# DigiLab API key — request one in #api on the DigiLab Discord
DIGILAB_API_KEY=

# Optional: set this to your server's guild ID while developing so slash
# commands sync instantly instead of waiting up to an hour for global sync.
GUILD_ID=

# Where the SQLite DB file lives (mount a volume over this in Docker)
DB_PATH=/data/faction_bot.db

# How often (minutes) the bot checks DigiLab for new local results
POLL_INTERVAL_MINUTES=15
